# ── GameBox configuration ────────────────────────────────────────────────────
# Copy to `.env` for docker/podman deployments, or export in your shell for dev.
# Local dev needs NOTHING set — it defaults to SQLite + email/password auth.

# Public origin users open in the browser.
#   dev:        http://localhost:5173
#   LAN (Pi):   https://lan.gamebox.yourdomain.com
#   VPS:        https://gamebox.yourdomain.com
BASE_URL=http://localhost:5173

# The backend's own origin (auth callbacks). In production behind one domain,
# set it to the SAME value as BASE_URL. In dev leave as localhost:3001.
BACKEND_URL=http://localhost:3001

# Backend listen port.
PORT=3001

# Postgres connection string. LEAVE EMPTY in dev to use a local SQLite file
# (gamebox.dev.sqlite). Production should always set this.
DATABASE_URL=
# e.g. DATABASE_URL=postgres://gamebox:yourpassword@postgres:5432/gamebox

# Session signing secret — REQUIRED in production. Generate one:
#   openssl rand -base64 32
AUTH_SECRET=dev-only-insecure-secret-change-me

# ── Auth methods ─────────────────────────────────────────────────────────────
# Development: email/password ON, Google OFF (no setup needed; run `npm run seed`
# for dummy users).  Production/final: flip this to false and fill in Google.
AUTH_EMAIL_PASSWORD_ENABLED=true

# Google OAuth (activates the "Continue with Google" button when BOTH are set).
# Setup steps are in README.md — the authorized redirect URI must be:
#   <BACKEND_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Family allowlist: comma-separated emails allowed to create an account.
# EMPTY = anyone can sign up (fine for dev, do NOT leave empty in production).
# Keep the @dev.local addresses while developing with seeded users.
ALLOWED_EMAILS=
# e.g. ALLOWED_EMAILS=you@gmail.com,partner@gmail.com,sister@gmail.com

# ── Tuning (defaults are fine) ───────────────────────────────────────────────
# DISCONNECT_GRACE_MS=60000       # before a dropped seat becomes vote-eligible
# PURGE_AFTER_DAYS=30             # stale lobby/active/paused games purge window
# SQLITE_PATH=gamebox.dev.sqlite  # dev database location
# FRONTEND_DIST=                  # prod only: path to apps/frontend/dist

# ── docker-compose only ──────────────────────────────────────────────────────
# DB_PASSWORD=change-me-too
